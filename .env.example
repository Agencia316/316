# Meta (Facebook) Ads API - Credenciais
# Copie este arquivo para .env e preencha com suas credenciais reais

# ID do App no Meta for Developers (https://developers.facebook.com/apps/)
FB_APP_ID=seu_app_id_aqui

# Secret do App no Meta for Developers
FB_APP_SECRET=seu_app_secret_aqui

# Access Token do usuario ou System User Token
# Gere em: https://developers.facebook.com/tools/explorer/
# Para producao, use um token de longa duracao (Long-Lived Token) ou System User Token
FB_ACCESS_TOKEN=seu_access_token_aqui
